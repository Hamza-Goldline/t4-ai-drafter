{
  "name": "t4-ai-drafter",
  "version": "1.0.8",
  "description": "An AI-powered email drafting tool for Twenty4 Storage",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Hamza Nawaz",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.7.3",
    "googleapis": "^170.0.0",
    "nodemon": "^3.1.11"
  },
  "devDependencies": {
    "electron-builder": "^26.7.0",
    "electron": "^39.2.7"
  },
  "build": {
    "appId": "com.twenty4storage.t4aidrafter",
    "productName": "T4 Ai Drafter",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "**/*",
      ".env",
      "credentials.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Hamza-Goldline",
        "repo": "t4-ai-drafter"
      }
    ]
  }
}